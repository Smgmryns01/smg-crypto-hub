# SMG Crypto Hub — Environment Variables
# Copy this file to .env.local and fill in your values

# Site
NEXT_PUBLIC_SITE_URL=https://smgcryptohub.xyz
NEXT_PUBLIC_SITE_NAME="SMG Crypto Hub"

# Contact form (add your email service API key at Milestone 6)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=smgcryptohub@gmail.com

# Crypto market data API (add at Milestone 6)
# NEXT_PUBLIC_COINGECKO_API_KEY=your_api_key_here

# ICP Internet Identity (add at Milestone 5)
# NEXT_PUBLIC_II_URL=https://identity.ic0.app
# NEXT_PUBLIC_CANISTER_ID_INTERNET_IDENTITY=rdmx6-jaaaa-aaaaa-aaadq-cai

# Analytics (optional, add before launch)
# NEXT_PUBLIC_ANALYTICS_ID=
